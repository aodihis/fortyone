# Bind address and port for the backend server.
# Use 0.0.0.0:<port> on a VPS to listen on all interfaces.
SERVER_ADDRESS=127.0.0.1:3000

# Allowed CORS origin.
# Use * for local development only.
# Set to your exact frontend URL in production (e.g. https://game.example.com).
ALLOWED_ORIGIN=*

# JWT signing secret — must be a long random string in production.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change_me_in_production

# Log verbosity: error | warn | info | debug | trace
LOG_LEVEL=info
