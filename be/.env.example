# Bind address and port for the backend server.
# Use 0.0.0.0:<port> on a VPS to listen on all interfaces.
SERVER_ADDRESS=127.0.0.1:3000

# Allowed CORS origin.
# Use * for local development only.
# Set to your exact frontend URL in production (e.g. https://game.example.com).
ALLOWED_ORIGIN=*

# JWT signing secret — must be a long random string in production.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change_me_in_production

# Log verbosity: error | warn | info | debug | trace
LOG_LEVEL=info

# Redis connection URL.
# Local dev (no auth):      redis://127.0.0.1:6379/
# With password:            redis://:yourpassword@127.0.0.1:6379/
# With username (Redis 6+): redis://default:yourpassword@127.0.0.1:6379/
# Docker Compose:           redis://redis:6379/
REDIS_URL=redis://127.0.0.1:6379/

# Redis key prefix — used to avoid collisions on a shared Redis instance.
REDIS_KEY_PREFIX=fortyone

# Reconnect grace period in seconds.
# If a player disconnects mid-game and does not reconnect within this time,
# the game is abandoned (or the remaining player auto-wins if only one is left).
RECONNECT_TIMEOUT_SECS=120
