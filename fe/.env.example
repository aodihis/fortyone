# Backend API URL — change to your VPS backend address for production builds.
# This is baked into the WASM binary at compile time, so rebuild after changing.
API_URL=http://127.0.0.1:3000

# Dev server settings — only used by `trunk serve` (not production).
# Set SERVE_ADDRESS=0.0.0.0 to expose on the network.
SERVE_PORT=8000
SERVE_ADDRESS=127.0.0.1
